# ─── Plataforma SL — Backend (variables de entorno) ───
# Copia este archivo a .env y rellena los valores. NUNCA subas .env al repo.

# Entorno: development | production
APP_ENV=development

# Base de datos (objetivo: PostgreSQL con psycopg3)
#   Producción/real:
# DATABASE_URL=postgresql+psycopg://usuario:password@localhost:5432/plataforma_sl
#   Dev rápido sin instalar Postgres (fallback SQLite, NO usar en producción):
DATABASE_URL=sqlite:///./plataforma_sl.db

# Seguridad / JWT — genera una clave fuerte: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=CAMBIAME_clave_debil_solo_dev
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# CORS: orígenes del frontend permitidos (coma-separados). NO uses "*" con credenciales.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Sembrar catálogos *_INICIAL al arrancar si las tablas están vacías (idempotente)
SEED_ON_STARTUP=true
