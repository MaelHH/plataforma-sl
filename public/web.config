<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS — Plataforma SL (frontend estático puro).
  SIN reverse proxy: el frontend habla con el backend por IP:puerto directo
  (VITE_API_URL en el build). Por eso NO necesita URL Rewrite ni ARR.
  Solo declara el documento por defecto.
-->
<configuration>
  <system.webServer>
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>
  </system.webServer>
</configuration>
