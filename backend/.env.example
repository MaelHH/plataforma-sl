# ── Base de datos ──
# DESARROLLO (tu laptop): SQLite, no instala nada, se crea un archivo dev.db
DATABASE_URL=sqlite:///./dev.db
# PRODUCCIÓN (VPS): PostgreSQL — descomenta y pon los datos que te dé TI
# DATABASE_URL=postgresql+psycopg://USUARIO:PASSWORD@HOST:5432/plataforma_sl

# ── Seguridad (login) ──
SECRET_KEY=cambia-esto-por-una-frase-larga-y-secreta
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Permisos para que el frontend (React/Vite) pueda llamar a la API ──
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
